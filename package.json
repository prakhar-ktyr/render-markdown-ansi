{
  "name": "render-markdown-ansi",
  "version": "1.1.2",
  "description": "Zero-dependency Markdown to ANSI terminal renderer. Converts Markdown strings into beautifully formatted terminal output with full GFM support.",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "mdview": "bin/mdview.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup --tsconfig tsconfig.build.json",
    "dev": "tsup --watch --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --project tsconfig.build.json --noEmit",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "prepublishOnly": "npm run build",
    "version": "git add CHANGELOG.md",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prakhar-ktyr/render-markdown-ansi.git"
  },
  "keywords": [
    "markdown",
    "ansi",
    "terminal",
    "cli",
    "renderer",
    "zero-dependency",
    "commonmark",
    "gfm",
    "formatting",
    "escape-codes",
    "console"
  ],
  "author": "Prakhar Katiyar",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/prakhar-ktyr/render-markdown-ansi/issues"
  },
  "homepage": "https://github.com/prakhar-ktyr/render-markdown-ansi#readme",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "fflate": "0.8.2"
  }
}
